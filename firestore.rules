rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Admin check: Prioritizes hardcoded emails for bootstrap, then checks DB roles.
    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email.lower() in ["vinita@reidiusinfra.com", "vinitaagrawalec@gmail.com"] && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function hasRole(role) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserRole() == role;
    }

    function isEngineer() {
      return isSignedIn() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserRole() in ['engineer', 'qa', 'site_supervisor', 'electrician', 'plumber', 'flooring_team', 'sales', 'architect'])
      );
    }

    // ===============================================================
    // Validation Helpers (Blueprints)
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role']) && 
             data.keys().size() == 4 &&
             data.uid == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email == request.auth.token.email &&
             data.role in ['engineer', 'admin', 'qa', 'site_supervisor', 'electrician', 'plumber', 'flooring_team', 'sales', 'architect'];
    }

    function isValidAttendance(data) {
      let required = ['userId', 'laborName', 'type', 'timestamp', 'dateStr', 'location'];
      return data.keys().hasAll(required) &&
             data.userId == request.auth.uid &&
             data.type in ['check-in', 'check-out'] &&
             (data.timestamp == request.time || data.timestamp is timestamp) &&
             data.location is map &&
             data.location.latitude is number &&
             data.location.longitude is number;
    }

    function isValidSiteReport(data) {
      let required = ['engineerId', 'engineerName', 'clientId', 'clientName', 'timestamp', 'dateStr', 'images', 'aiAnalysis', 'location'];
      return data.keys().hasAll(required) &&
             data.engineerId == request.auth.uid &&
             data.images is list && data.images.size() <= 6 &&
             (data.timestamp == request.time || data.timestamp is timestamp) &&
             data.location is map;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin()) && isValidUser(incoming()) && (
        (incoming().role == existing().role) || isAdmin()
      );
    }

    match /attendance/{attendanceId} {
      allow read: if isAdmin() || hasRole('sales') || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isEngineer() && isValidId(attendanceId) && isValidAttendance(incoming());
      allow update: if isAdmin() || (isOwner(resource.data.userId) && isValidAttendance(incoming()));
      allow delete: if isAdmin();
    }

    match /site_reports/{reportId} {
      allow read: if isAdmin() || hasRole('sales') || hasRole('qa') || (isSignedIn() && resource.data.engineerId == request.auth.uid);
      allow create: if isEngineer() && isValidId(reportId) && isValidSiteReport(incoming());
      allow update: if isAdmin() || (isOwner(resource.data.engineerId) && isValidSiteReport(incoming()));
      allow delete: if isAdmin();
    }

    match /clients/{clientId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /safety_checkpoints/{checkpointId} {
      allow read: if isEngineer();
      allow write: if isAdmin();
    }

    match /report_heads/{headId} {
      allow read: if isEngineer();
      allow write: if isAdmin();
    }

    match /design_requirements/{reqId} {
      allow read: if isEngineer();
      allow create: if isEngineer() && incoming().engineerId == request.auth.uid;
      allow update: if isAdmin() || hasRole('architect') || isOwner(resource.data.engineerId);
      allow delete: if isAdmin();
    }
  }
}
